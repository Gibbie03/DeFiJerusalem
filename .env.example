# Copy to .env for local development. In production (Render), set these as
# environment variables/secrets in the service dashboard instead of a file.

# Neon Postgres connection string (required)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Express session signing secret (required in production)
SESSION_SECRET=

# Optional integrations - features degrade gracefully if unset
GOPLUS_API_KEY=
ETHERSCAN_API_KEY=
TWITTER_BEARER_TOKEN=

# One-time secret used to bootstrap the first admin account
ADMIN_BOOTSTRAP_SECRET=

# Server port (Render sets this automatically; default 5000 for local dev)
PORT=5000
